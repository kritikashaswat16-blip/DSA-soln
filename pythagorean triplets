def pythagorean_triplets(limit):
    triplets = []
    for a in range(1, limit + 1):
        for b in range(a, limit + 1):
            c_sq = a*a + b*b
            c = int(c_sq**0.5)
            if c*c == c_sq and c <= limit:
                triplets.append((a, b, c))
    return triplets

# Test
print(pythagorean_triplets(20))  # [(3,4,5), (5,12,13), (6,8,10), ...]
